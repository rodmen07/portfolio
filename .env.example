# Root environment template for the Portfolio workspace.
#
# Copy to `.env` and fill in real values for local development.
# `.env` is gitignored. NEVER commit real secrets.
#
# Most services read these from process environment, Secret Manager, or
# Fly.io secrets in production; this file is only for local runs.

# ---- Shared auth ----
# Symmetric secret used by JWT issuance (auth-service) and validation
# (every Rust microservice). Must match across all services.
AUTH_JWT_SECRET=dev-insecure-secret-change-me

# ---- Databases ----
# Per-service databases follow the pattern <service>_dev.
# Example local Postgres URLs:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/infraportal_dev
TEST_DATABASE_URL=sqlite::memory:

# ---- OAuth (auth-service) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# ---- LLM providers (ai-orchestrator-service) ----
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- AWS (dynamodb_prototype) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DYNAMODB_TABLE=portfolio-events-dev

# ---- GCP (used by gcp-setup.sh and Terraform) ----
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_ARTIFACT_REGISTRY=infraportal

# ---- Observaboard ----
DJANGO_SECRET_KEY=dev-insecure-django-secret
CELERY_BROKER_URL=redis://localhost:6379/0
INGEST_API_KEY=dev-ingest-key

# ---- Optional sinks ----
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
